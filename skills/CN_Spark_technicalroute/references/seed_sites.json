{
  "comment": "学术文献样式检索站点。literature_search.py 会按 priority 顺序逐个尝试，直到累计抓到 N 张候选参考图。可自定义增删站点，每条 search_template 中 {q} 会被替换为 URL-encoded 主题词。",
  "default_max_refs": 8,
  "min_refs": 5,
  "sites": [
    {
      "name": "GoogleScholar",
      "priority": 1,
      "kind": "scholar",
      "search_template": "https://scholar.google.com/scholar?q={q}+%22technical+route%22+OR+%22research+framework%22+OR+%22%E6%8A%80%E6%9C%AF%E8%B7%AF%E7%BA%BF%22",
      "needs_login": false,
      "notes": "结果页含 PDF 直链与 figure 缩略。Claude Code 用 WebSearch + WebFetch 抓取。"
    },
    {
      "name": "SemanticScholar",
      "priority": 2,
      "kind": "scholar",
      "search_template": "https://api.semanticscholar.org/graph/v1/paper/search?query={q}&fields=title,abstract,year,externalIds,openAccessPdf&limit=20",
      "needs_login": false,
      "notes": "API 返回 JSON。openAccessPdf.url 字段可直接 fetch PDF。"
    },
    {
      "name": "ScienceDirect",
      "priority": 3,
      "kind": "publisher",
      "search_template": "https://www.sciencedirect.com/search?qs={q}",
      "needs_login": false,
      "notes": "Elsevier 期刊，结果页含 abstract + 部分 figure 缩略。"
    },
    {
      "name": "CNKI",
      "priority": 4,
      "kind": "cn_scholar",
      "search_template": "https://search.cnki.net/search.aspx?q={q}",
      "needs_login": true,
      "notes": "中文文献。访问受限时跳过；可让用户人工补图。"
    },
    {
      "name": "arXiv",
      "priority": 5,
      "kind": "preprint",
      "search_template": "https://arxiv.org/search/?searchtype=all&query={q}",
      "needs_login": false,
      "notes": "计算 / 算法 / ML 类工作流图最丰富。返回 PDF 链接。"
    },
    {
      "name": "WikimediaCommons",
      "priority": 6,
      "kind": "image_commons",
      "search_template": "https://commons.wikimedia.org/w/index.php?search={q}+research+framework&title=Special:MediaSearch&go=Go&type=image",
      "needs_login": false,
      "notes": "CC 授权图片，可直接下载。学术信息图较少但风格干净。"
    },
    {
      "name": "ResearchGate",
      "priority": 7,
      "kind": "scholar_network",
      "search_template": "https://www.researchgate.net/search/publication?q={q}",
      "needs_login": true,
      "notes": "登陆受限。优先级低，作为备选。"
    },
    {
      "name": "BaiduScholar",
      "priority": 8,
      "kind": "cn_scholar",
      "search_template": "https://xueshu.baidu.com/s?wd={q}",
      "needs_login": false,
      "notes": "中文文献的轻量补充检索。"
    }
  ],
  "image_filter_hints": {
    "good": ["technical route", "research framework", "research design", "study workflow", "conceptual framework", "技术路线", "研究框架", "研究设计"],
    "bad":  ["histogram", "scatter plot", "regression", "boxplot", "heatmap", "ROC", "loss curve"],
    "min_aspect": 1.2,
    "max_aspect": 3.0,
    "min_width_px": 800
  }
}
